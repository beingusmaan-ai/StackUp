generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  name             String
  email            String   @unique
  passwordHash     String?
  role             String   @default("TEAM_MEMBER")
  marketingRole    String?
  department       String?
  isActive         Boolean  @default(true)
  image            String?
  avatarData       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  accounts              Account[]
  sessions              Session[]
  createdTasks          Task[]               @relation("TaskCreator")
  assignedTasks         TaskAssignee[]
  taskComments          TaskComment[]
  createdCampaigns      Campaign[]           @relation("CampaignOwner")
  approvalRequests      ApprovalRequest[]    @relation("ApprovalRequester")
  approvalDecisions     ApprovalRequest[]    @relation("ApprovalDecider")
  notifications         Notification[]
  activityLogs          TaskActivity[]
  timeEntries           TimeEntry[]
  recurringTemplates    RecurringTemplate[]  @relation("RecurringCreator")
  departmentMemberships DepartmentMember[]
  campaignTemplates     CampaignTemplate[]   @relation("TemplateCreator")
  taskTemplates         TaskTemplate[]       @relation("TaskTemplateCreator")
  templateVersions      TemplateVersion[]    @relation("TemplateVersionCreator")
  workspaceMemberships  WorkspaceMember[]
  conversationMembers   ConversationMember[]
  sentMessages          Message[]
  createdDocs           Doc[]                @relation("DocCreator")
  docShares             DocShare[]
  calendarEvents        CalendarEvent[]      @relation("UserCalendarEvents")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Department {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String   @default("#6366f1")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members          DepartmentMember[]
  campaigns        Campaign[]
  templates        CampaignTemplate[]
  taskTemplates    TaskTemplate[]
  requestedTasks   Task[]             @relation("TaskRequestingDept")
  assignedTasks    Task[]             @relation("TaskAssignedDept")

  @@map("departments")
}

model DepartmentMember {
  departmentId String
  userId       String
  role         String   @default("MEMBER")
  joinedAt     DateTime @default(now())

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([departmentId, userId])
  @@map("department_members")
}

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  color       String   @default("#e8170b")
  logoUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaigns Campaign[]
  members   WorkspaceMember[]

  @@map("workspaces")
}

model WorkspaceMember {
  workspaceId String
  userId      String
  role        String   @default("MEMBER")
  joinedAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
  @@map("workspace_members")
}

model CampaignTemplate {
  id            String   @id @default(cuid())
  name          String
  description   String?
  departmentId  String?
  templateTasks String?
  createdById   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  createdBy  User        @relation("TemplateCreator", fields: [createdById], references: [id])

  @@map("campaign_templates")
}

model Campaign {
  id           String   @id @default(cuid())
  name         String
  description  String?
  status       String   @default("DRAFT")
  startDate    DateTime
  endDate      DateTime
  budget       Float?
  goals        String?
  ownerId      String
  departmentId String?
  workspaceId  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner              User                @relation("CampaignOwner", fields: [ownerId], references: [id])
  department         Department?         @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  workspace          Workspace?          @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  tasks              Task[]
  folders            ProjectFolder[]
  recurringTemplates RecurringTemplate[]
  docs               Doc[]

  @@index([departmentId])
  @@index([workspaceId])
  @@map("campaigns")
}

model ProjectFolder {
  id         String     @id @default(cuid())
  name       String
  color      String     @default("#6366f1")
  position   Int        @default(0)
  campaignId String
  campaign   Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lists      TaskList[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([campaignId])
  @@map("project_folders")
}

model TaskList {
  id        String        @id @default(cuid())
  name      String
  color     String        @default("#6366f1")
  position  Int           @default(0)
  folderId  String
  folder    ProjectFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  tasks     Task[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([folderId])
  @@map("task_lists")
}

model Task {
  id                  String    @id @default(cuid())
  title               String
  description         String?
  taskType            String?
  status              String    @default("TODO")
  priority            String    @default("MEDIUM")
  startDate           DateTime?
  dueDate             DateTime?
  estimatedHours      Float?
  position            Int       @default(0)
  campaignId             String?
  listId                 String?
  parentTaskId           String?
  createdById            String
  approvedById           String?
  recurringTemplateId    String?
  requestingDepartmentId String?
  assignedDepartmentId   String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  completedAt            DateTime?

  campaign             Campaign?          @relation(fields: [campaignId], references: [id])
  list                 TaskList?          @relation(fields: [listId], references: [id], onDelete: SetNull)
  requestingDepartment Department?        @relation("TaskRequestingDept", fields: [requestingDepartmentId], references: [id], onDelete: SetNull)
  assignedDepartment   Department?        @relation("TaskAssignedDept", fields: [assignedDepartmentId], references: [id], onDelete: SetNull)
  parentTask        Task?              @relation("SubTasks", fields: [parentTaskId], references: [id])
  subTasks          Task[]             @relation("SubTasks")
  createdBy         User               @relation("TaskCreator", fields: [createdById], references: [id])
  recurringTemplate RecurringTemplate? @relation(fields: [recurringTemplateId], references: [id], onDelete: SetNull)
  assignees         TaskAssignee[]
  comments          TaskComment[]
  attachments       TaskAttachment[]
  approvalRequests  ApprovalRequest[]
  activityLog       TaskActivity[]
  notifications     Notification[]
  timeEntries       TimeEntry[]
  checklist         TaskChecklist[]
  docs              Doc[]
  calendarEvents    CalendarEvent[]

  @@index([status])
  @@index([dueDate])
  @@index([campaignId])
  @@index([listId])
  @@index([recurringTemplateId])
  @@index([assignedDepartmentId])
  @@index([requestingDepartmentId])
  @@map("tasks")
}

model TaskAssignee {
  taskId     String
  userId     String
  assignedAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
  @@map("task_assignees")
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String
  content   String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task    Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author  User          @relation(fields: [authorId], references: [id])
  parent  TaskComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies TaskComment[] @relation("CommentReplies")

  @@index([taskId, createdAt])
  @@map("task_comments")
}

model TaskAttachment {
  id         String   @id @default(cuid())
  taskId     String
  fileName   String
  fileUrl    String
  fileSize   Int
  mimeType   String
  source     String   @default("upload")
  externalId String?
  uploadedAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_attachments")
}

model SlackConfig {
  id              String   @id @default(cuid())
  webhookUrl      String
  channel         String?
  enabled         Boolean  @default(true)
  notifyOnStatus  Boolean  @default(true)
  notifyOnAssign  Boolean  @default(true)
  notifyOnOverdue Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("slack_configs")
}

model TaskActivity {
  id        String   @id @default(cuid())
  taskId    String
  actorId   String
  action    String
  fromValue String?
  toValue   String?
  createdAt DateTime @default(now())

  task  Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor User @relation(fields: [actorId], references: [id])

  @@index([taskId])
  @@map("task_activities")
}

model ApprovalRequest {
  id           String   @id @default(cuid())
  taskId       String
  requesterId  String
  deciderId    String?
  status       String   @default("PENDING")
  message      String?
  decisionNote String?
  decidedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  task      Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  requester User  @relation("ApprovalRequester", fields: [requesterId], references: [id])
  decider   User? @relation("ApprovalDecider", fields: [deciderId], references: [id])

  @@index([status])
  @@map("approval_requests")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  taskId    String?
  createdAt DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId, isRead])
  @@map("notifications")
}

model TimeEntry {
  id        String   @id @default(cuid())
  userId    String
  taskId    String?
  date      DateTime
  hours     Float
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@map("time_entries")
}

model RecurringTemplate {
  id             String    @id @default(cuid())
  title          String
  description    String?
  taskType       String?
  priority       String    @default("MEDIUM")
  estimatedHours Float?
  campaignId     String?
  createdById    String

  // Recurrence pattern
  frequency      String    // DAILY | WEEKLY | MONTHLY
  interval       Int       @default(1)
  weekDays       String?   // comma-sep integers: "1,3,5" (0=Sun, 1=Mon, …, 6=Sat)
  monthDay       Int?      // 1–31

  // Assignees stored as comma-separated user IDs
  assigneeIds    String?

  // Schedule bounds
  startDate      DateTime
  endType        String    @default("NEVER") // NEVER | ON_DATE | AFTER_COUNT
  endDate        DateTime?
  endCount       Int?

  // State
  isActive       Boolean   @default(true)
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  generatedCount Int       @default(0)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  createdBy  User      @relation("RecurringCreator", fields: [createdById], references: [id])
  campaign   Campaign? @relation(fields: [campaignId], references: [id])
  tasks      Task[]

  @@index([isActive, nextRunAt])
  @@map("recurring_templates")
}

model TaskTemplate {
  id              String    @id @default(cuid())
  name            String
  description     String?
  category        String    @default("CUSTOM")
  departmentId    String?
  defaultPriority String    @default("MEDIUM")
  estimatedDays   Int?
  tags            String?
  isArchived      Boolean   @default(false)
  isBuiltIn       Boolean   @default(false)
  createdById     String
  lastUsedAt      DateTime?
  useCount        Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  department Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  createdBy  User             @relation("TaskTemplateCreator", fields: [createdById], references: [id])
  groups     TemplateGroup[]
  versions   TemplateVersion[]

  @@index([category])
  @@index([isArchived])
  @@map("task_templates")
}

model Conversation {
  id        String   @id @default(cuid())
  type      String   // DIRECT | GROUP
  name      String?
  teamId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  ConversationMember[]
  messages Message[]

  @@map("conversations")
}

model ConversationMember {
  id             String    @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime?
  joinedAt       DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@map("conversation_members")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

model TemplateGroup {
  id         String   @id @default(cuid())
  templateId String
  name       String
  color      String   @default("#6366f1")
  position   Int      @default(0)
  createdAt  DateTime @default(now())

  template TaskTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  tasks    TemplateTask[]

  @@index([templateId])
  @@map("template_groups")
}

model TemplateTask {
  id             String   @id @default(cuid())
  groupId        String
  title          String
  description    String?
  taskType       String?
  assignedRole   String?
  priority       String   @default("MEDIUM")
  estimatedHours Float?
  dayOffset      Int?
  position       Int      @default(0)
  createdAt      DateTime @default(now())

  group        TemplateGroup        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  checklist    TemplateChecklist[]
  dependsOn    TemplateDependency[] @relation("DepTask")
  dependedOnBy TemplateDependency[] @relation("DepDepends")

  @@index([groupId])
  @@map("template_tasks")
}

model TemplateChecklist {
  id             String @id @default(cuid())
  templateTaskId String
  text           String
  position       Int    @default(0)

  templateTask TemplateTask @relation(fields: [templateTaskId], references: [id], onDelete: Cascade)

  @@index([templateTaskId])
  @@map("template_checklists")
}

model TemplateDependency {
  id          String @id @default(cuid())
  taskId      String
  dependsOnId String

  task      TemplateTask @relation("DepTask", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOn TemplateTask @relation("DepDepends", fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnId])
  @@map("template_dependencies")
}

model TemplateVersion {
  id          String   @id @default(cuid())
  templateId  String
  version     Int
  snapshot    String
  note        String?
  createdById String
  createdAt   DateTime @default(now())

  template  TaskTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  createdBy User         @relation("TemplateVersionCreator", fields: [createdById], references: [id])

  @@index([templateId])
  @@map("template_versions")
}

model TaskChecklist {
  id        String   @id @default(cuid())
  taskId    String
  text      String
  isChecked Boolean  @default(false)
  position  Int      @default(0)
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_checklists")
}

model Doc {
  id          String   @id @default(cuid())
  title       String   @default("Untitled")
  content     Json?
  icon        String?
  parentId    String?
  campaignId  String?
  taskId      String?
  createdById String
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User       @relation("DocCreator", fields: [createdById], references: [id])
  parent    Doc?       @relation("DocChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children  Doc[]      @relation("DocChildren")
  shares    DocShare[]
  campaign  Campaign?  @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  task      Task?      @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([parentId])
  @@index([campaignId])
  @@index([taskId])
  @@map("docs")
}

model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  allDay      Boolean  @default(false)
  type        String   @default("MEETING")
  color       String?
  userId      String
  taskId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User  @relation("UserCalendarEvents", fields: [userId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId, startTime])
  @@map("calendar_events")
}

model DocShare {
  id        String   @id @default(cuid())
  docId     String
  userId    String
  role      String   @default("VIEWER")
  createdAt DateTime @default(now())

  doc  Doc  @relation(fields: [docId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([docId, userId])
  @@map("doc_shares")
}
